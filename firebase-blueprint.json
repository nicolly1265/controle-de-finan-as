{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User preferences and system profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "BankAccount": {
      "title": "Bank Account",
      "description": "Linked bank accounts containing mock API tokens",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bankName": { "type": "string" },
        "accountType": { "type": "string" },
        "balance": { "type": "number" },
        "accountNumber": { "type": "string" },
        "status": { "type": "string" },
        "lastSyncedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "bankName", "balance", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Income or expense item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "bankAccountId": { "type": "string" },
        "bankName": { "type": "string" },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "description", "amount", "type", "category", "date"]
    },
    "Budget": {
      "title": "Monthly Budget",
      "description": "Category monthly spending limit",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "limit": { "type": "number" },
        "spent": { "type": "number" },
        "month": { "type": "string" },
        "autoGenerated": { "type": "boolean" },
        "aiExplanation": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "category", "limit", "month"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Root user profile"
    },
    "users/{userId}/bankAccounts/{bankAccountId}": {
      "schema": "BankAccount",
      "description": "Linked bank accounts"
    },
    "users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transactions log"
    },
    "users/{userId}/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "Category spending limits and monthly budgets"
    }
  }
}
